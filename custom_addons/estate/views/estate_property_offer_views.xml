<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="estate_property_offer_tree_view" model="ir.ui.view">
        <field name="name">estate.property.offer.view.tree</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <list editable="top" decoration-success="status == 'accepted'" decoration-danger="status == 'refused'">
                <field name="property_id"/>
                <field name="partner_id"/>
                <field name="price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="property_type_id"/>
                <field name="validity" />
                <field name="date_deadline" />
                <!-- <field name="status" widget="badge" decoration-success="status == 'accepted'" decoration-danger="status == 'refused'"/> -->
                <button string="Accept" name="action_accept" type="object" icon="fa-check"/>
                <button string="Refuse" name="action_refuse" type="object" icon="fa-close"/>
            </list>
        </field>
    </record>

    <record id="estate_property_offer_form_view" model="ir.ui.view">
        <field name="name">estate.property.offer.view.form</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="property_id"/>
                        <field name="property_type_id"/>
                        <field name="partner_id"/>
                        <field name="price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                    </group>
                    <group>
                        <field name="validity" />
                        <field name="date_deadline" />
                        <field name="status" widget="radio"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="estate_property_offer_search_view" model="ir.ui.view">
        <field name="name">estate.property.offer.view.search</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <search>
                <field name="property_id"/>
                <field name="partner_id"/>
                <field name="price"/>
                <field name="property_type_id"/>

                <filter name="filter_accepted" string="Accepted" domain="[('status', '=', 'accepted')]"/>
                <filter name="filter_refused" string="Refused" domain="[('status', '=', 'refused')]"/>

                <filter name="group_by_property_type" string="Property Type" context="{'group_by': 'property_type_id'}"/>
                <filter name="group_by_status" string="Status" context="{'group_by': 'status'}"/>
            </search>
        </field>
    </record>

    <record id="estate_property_offer_action" model="ir.actions.act_window">
        <field name="name">Property Offers</field>
        <field name="res_model">estate.property.offer</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
