<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="estate_property_type_tree_view" model="ir.ui.view">
        <field name="name">estate.property.type.view.tree</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="estate_property_type_form_view" model="ir.ui.view">
        <field name="name">estate.property.type.view.form</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box">
                        <button name="action_open_property_id" type="object" class="oe_stat_button" icon="fa-list">
                            <field name="property_count" string="Properties" widget="linecount"/>
                        </button>
                    </div>
                    <group>
                        <field name="name" />
                    </group>
                    <notebook>
                        <page name="properties" string="Properties">
                            <field name="property_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="expected_price"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="estate_property_type_search_view" model="ir.ui.view">
        <field name="name">estate.property.type.view.search</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter name="group_by_property" string="Properties" context="{'group_by': 'property_ids'}"/>
            </search>
        </field>
    </record>

    <record id="estate_property_type_action" model="ir.actions.act_window">
        <field name="name">Property Types</field>
        <field name="res_model">estate.property.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
